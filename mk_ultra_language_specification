13.3 Platform Detection

```pascal
@comptime
function current_platform(): Platform
begin
    if @target_os() == "linux" then
        return .Linux
    elsif @target_os() == "windows" then
        return .Windows
    elsif @target_os() == "macos" then
        return .MacOS
    elsif @target_os() == "freebsd" then
        return .FreeBSD
    elsif @target_os() == "openbsd" then
        return .OpenBSD
    elsif @target_os() == "netbsd" then
        return .NetBSD
    elsif @target_os() == "dragonfly" then
        return .DragonFlyBSD
    else
        @compile_error("Unsupported platform")
    end
end
```

